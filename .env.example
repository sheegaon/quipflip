# Database
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://quipflip:quipflip@localhost:5432/quipflip

# SQLite (development/testing fallback)
# DATABASE_URL=sqlite+aiosqlite:///./quipflip.db

# Redis (optional, falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Application
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
CROWDCRAFT_RUNTIME_ROOT=~/Library/Application Support/Crowdcraft
CROWDCRAFT_STATIC_ROOT=
CROWDCRAFT_LOG_DIR=~/Library/Logs/Crowdcraft
CROWDCRAFT_RELEASE_ID=
CROWDCRAFT_EXPECTED_REVISION=
CROWDCRAFT_WORKERS=1
CROWDCRAFT_TRUST_PROXY=false
PHRASE_VALIDATOR_URL=http://localhost:8001
AI_PROVIDER=openai

# Email / SMTP (magic-link delivery)
# Leave SMTP_HOST empty to disable email sending. In development the mailer
# logs and skips delivery; in production an empty SMTP_HOST makes the
# magic-link endpoint return 503 magic_link_email_failed.
#
# Values below are for Resend (https://resend.com). Username is the literal
# string "resend"; the password is your Resend API key (re_...). Keep the API
# key OUT of this file in production — load it from the Keychain instead (see
# scripts/ops/crowdcraft_ops.py secrets keychain-store --with-smtp).
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_your_resend_api_key
SMTP_FROM_ADDRESS=no-reply@crowdcraftlabs.com
SMTP_FROM_NAME=Crowdcraft
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
