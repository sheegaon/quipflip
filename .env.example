# Database
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://quipflip:quipflip@localhost:5432/quipflip

# SQLite (development/testing fallback)
# DATABASE_URL=sqlite+aiosqlite:///./quipflip.db

# Redis (optional, falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Application
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
CROWDCRAFT_RUNTIME_ROOT=~/Library/Application Support/Crowdcraft
CROWDCRAFT_STATIC_ROOT=
CROWDCRAFT_LOG_DIR=~/Library/Logs/Crowdcraft
CROWDCRAFT_RELEASE_ID=
CROWDCRAFT_EXPECTED_REVISION=
CROWDCRAFT_WORKERS=1
CROWDCRAFT_TRUST_PROXY=false
PHRASE_VALIDATOR_URL=http://localhost:8001
AI_PROVIDER=openai
